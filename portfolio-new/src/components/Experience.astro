---
import { experienceData } from '../lib/data'

function initials(company: string) {
  return company.split(' ')[0][0].toUpperCase()
}
---

<section class="sr pb-10">
  <span class="lbl">places i worked at</span>

  <div class="space-y-6">
    {experienceData.map((job) => (
      <div class="flex gap-3">
        <!-- Company avatar: logo if available, fallback to initials -->
        <div class="shrink-0 w-8 h-8 rounded-full bg-bg2 border border-border flex items-center justify-center text-xs font-semibold text-fg2 mt-0.5 overflow-hidden">
          {job.logoUrl
            ? <img
                src={job.logoUrl}
                alt={job.company}
                width="32"
                height="32"
                class="w-full h-full object-cover"
                onError="this.style.display='none';this.nextElementSibling.style.display='flex'"
              />
            : null}
          <span
            style={job.logoUrl ? 'display:none' : ''}
            class="w-full h-full flex items-center justify-center"
          >
            {initials(job.company)}
          </span>
        </div>

        <div class="flex-1 min-w-0">
          <!-- Company + date -->
          <div class="flex items-start justify-between gap-2">
            <p class="text-sm font-medium text-fg leading-snug">{job.company}</p>
            <p class="text-xs text-fg2 whitespace-nowrap shrink-0 font-mono mt-0.5">{job.duration.split('–')[0].trim().toLowerCase()}{' – '}{job.duration.split('–')[1]?.trim().toLowerCase() ?? 'present'}</p>
          </div>

          <!-- Role -->
          <p class="text-xs text-fg2 mt-0.5 mb-2">{job.role.toLowerCase()} · {job.location.split(',')[0].toLowerCase()}</p>

          <!-- Bullets -->
          <ul class="space-y-1">
            {job.bullets.map((b) => (
              <li class="text-sm text-fg2 leading-relaxed flex gap-2">
                <span class="text-fg3 shrink-0">-</span>
                <span>
                  {Array.isArray(b)
                    ? b.map((part, i) =>
                        i % 2 === 1
                          ? <span class="text-fg font-medium">{part}</span>
                          : part
                      )
                    : b}
                </span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    ))}
  </div>
</section>
