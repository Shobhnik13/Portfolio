---
import { meta } from '../lib/data'

const birthDate = new Date(2003, 6, 13)
const today = new Date()
let age = today.getFullYear() - birthDate.getFullYear()
if (
  today.getMonth() < birthDate.getMonth() ||
  (today.getMonth() === birthDate.getMonth() && today.getDate() < birthDate.getDate())
) age--
---

<section class="pt-4 pb-10">
  <div class="flex items-start justify-between gap-6">
    <!-- Left -->
    <div>
      <h1 class="text-xl font-semibold text-fg tracking-tight mb-1">
        hi, shobhnik here
      </h1>
      <p class="text-fg2 text-sm">
        {age} · he/him · india
      </p>

      {meta.openToCollaborate && (
        <span class="inline-flex items-center gap-1.5 mt-2 text-[11px] font-medium text-fg2 border border-border rounded-full px-2.5 py-0.5">
          <span class="relative flex h-1.5 w-1.5">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-500 opacity-60"></span>
            <span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-green-500"></span>
          </span>
          open to collaborate
        </span>
      )}

      <!-- Clock + visitors -->
      <div class="flex items-center gap-3 mt-2 flex-wrap">
        <span class="text-xs text-fg3 font-mono flex items-center gap-1.5">
          <span class="inline-block w-1.5 h-1.5 rounded-full bg-fg3 opacity-60"></span>
          gurugram, IST&nbsp;<span id="ist-clock">--:--:--</span>
        </span>
        <span id="visitor-wrap" class="text-xs text-fg3 font-mono hidden">
          · <span id="visitor-count"></span> visitors
        </span>
      </div>
    </div>

    <!-- Profile image -->
    <img
      src="/IntroImg.jpeg"
      alt="shobhnik"
      class="w-14 h-14 rounded-full object-cover shrink-0 grayscale opacity-90"
    />
  </div>
</section>

<script>
  function initClock() {
    const clockEl = document.getElementById('ist-clock')
    if (!clockEl) return

    function updateClock() {
      const ist = new Date(Date.now() + (5 * 60 + 30) * 60 * 1000)
      const h = String(ist.getUTCHours()).padStart(2, '0')
      const m = String(ist.getUTCMinutes()).padStart(2, '0')
      const s = String(ist.getUTCSeconds()).padStart(2, '0')
      clockEl.textContent = `${h}:${m}:${s}`
    }

    updateClock()
    // clear any interval left from a previous visit to this page
    clearInterval((window as any).__clockInterval)
    ;(window as any).__clockInterval = setInterval(updateClock, 1000)
  }

  // ── Visitor counter (runs once per session) ────────────────
  function initVisitor() {
    const wrap  = document.getElementById('visitor-wrap')
    const count = document.getElementById('visitor-count')
    if (!wrap || !count || (window as any).__visitorFetched) return
    ;(window as any).__visitorFetched = true

    fetch('https://api.counterapi.dev/v1/shobhnik-portfolio/visits/up')
      .then((r) => r.json())
      .then((d) => {
        if (d?.count) {
          count.textContent = Number(d.count).toLocaleString()
          wrap.classList.remove('hidden')
        }
      })
      .catch(() => {})
  }

  initClock()
  initVisitor()
  // re-init clock on every navigation back to home
  document.addEventListener('astro:page-load', () => { initClock(); initVisitor() })
</script>
