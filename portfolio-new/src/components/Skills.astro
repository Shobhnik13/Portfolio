---
import { skillData } from '../lib/data'
---

<section class="sr pb-10">
  <span class="lbl">skills / tools</span>

  <div class="space-y-5">
    {skillData.map((cat) => (
      <div>
        <!-- Category label -->
        <p class="text-[10px] uppercase tracking-widest text-fg3 font-medium mb-2">
          {cat.category}
        </p>

        <!-- Skill pills -->
        <div class="flex flex-wrap gap-1.5">
          {cat.skills.map((skill) => (
            <span class="skill-pill">
              {skill}
            </span>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .skill-pill {
    display: inline-flex;
    align-items: center;
    padding: 3px 10px;
    border-radius: 999px;
    font-size: 11px;
    font-family: ui-monospace, 'Geist Mono', monospace;
    color: hsl(var(--fg2));
    border: 1px solid hsl(var(--border));
    background: hsl(var(--bg2));
    transition: color 0.15s ease, border-color 0.15s ease;
    white-space: nowrap;
  }
  .skill-pill:hover {
    color: hsl(var(--fg));
    border-color: hsl(var(--fg2));
  }
</style>
