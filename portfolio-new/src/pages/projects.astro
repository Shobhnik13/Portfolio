---
import Layout from '../layouts/Layout.astro'
import { projectData } from '../lib/data'
---

<Layout title="projects. — shobhnik">
  <section class="pb-10">
    <!-- Back button -->
    <a href="/" class="inline-flex items-center gap-1.5 text-sm text-fg2 hover:text-fg transition-colors mb-8 group">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:-translate-x-0.5">
        <path d="m12 19-7-7 7-7"/><path d="M19 12H5"/>
      </svg>
      home
    </a>

    <h1 class="text-xl font-semibold text-fg tracking-tight mb-1">projects.</h1>
    <p class="text-sm text-fg2 mb-8">things i've built — full stack and backend.</p>

    <!-- Filter -->
    <div class="flex gap-1.5 mb-8">
      {(['all', 'fullstack', 'backend'] as const).map((t) => (
        <button
          data-tab={t}
          class={`tab text-xs px-3 py-1 rounded-full border border-border transition-all
            ${t === 'all' ? 'bg-fg text-bg border-fg' : 'text-fg2 hover:text-fg hover:border-fg2'}`}
        >
          {t === 'fullstack' ? 'full stack' : t}
        </button>
      ))}
    </div>

    <!-- List -->
    <div class="space-y-0" id="list">
      {projectData.map((p) => (
        <article
          data-type={p.type}
          class="proj py-5 border-t border-border"
        >
          <!-- Row 1: title + icons -->
          <div class="flex items-start justify-between gap-4 mb-2">
            <div class="flex items-center gap-2 flex-wrap">
              <h2 class="text-sm font-semibold text-fg">{p.title}</h2>
            </div>
            <div class="flex gap-2 shrink-0">
              {p.gitLink && (
                <a href={p.gitLink} target="_blank" rel="noopener" class="text-fg2 hover:text-fg transition-colors" title="GitHub">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.4 5.4 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/>
                    <path d="M9 18c-4.51 2-5-2-7-2"/>
                  </svg>
                </a>
              )}
              {p.liveLink && (
                <a href={p.liveLink} target="_blank" rel="noopener" class="text-fg2 hover:text-fg transition-colors" title="Live">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M7 7h10v10"/><path d="M7 17 17 7"/>
                  </svg>
                </a>
              )}
            </div>
          </div>

          <!-- Tech stack -->
          <p class="text-[11px] text-fg2 font-mono mb-2.5">
            {p.techStack.join(' · ')}
          </p>

          <!-- Bullets -->
          <ul class="space-y-1">
            {p.overview.map((pt) => (
              <li class="text-sm text-fg2 leading-relaxed flex gap-2">
                <span class="text-fg3 shrink-0">-</span>
                {pt}
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </section>
</Layout>

<script>
  const tabs  = document.querySelectorAll<HTMLButtonElement>('.tab')
  const items = document.querySelectorAll<HTMLElement>('.proj')

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const sel = tab.dataset.tab!

      tabs.forEach((t) => {
        const on = t.dataset.tab === sel
        t.classList.toggle('bg-fg',      on)
        t.classList.toggle('text-bg',    on)
        t.classList.toggle('border-fg',  on)
        t.classList.toggle('text-fg2',  !on)
        t.classList.toggle('border-border', !on)
      })

      items.forEach((item) => {
        item.style.display = (sel === 'all' || item.dataset.type === sel) ? '' : 'none'
      })
    })
  })
</script>
