---
import Layout from '../layouts/Layout.astro'
import Intro from '../components/Intro.astro'
import AboutMe from '../components/AboutMe.astro'
import GithubContributions from '../components/GithubContributions.tsx'
import HireMe from '../components/HireMe.astro'
import Experiences from '../components/Experiences.astro'
import Skills from '../components/Skills.astro'
import Contact from '../components/Contact.astro'
---

<Layout title="Shobhnik — Portfolio">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 pt-28 md:pt-32">
    <Intro />
    <AboutMe />
    <HireMe />
    <GithubContributions client:idle />
    <Experiences />
    <Skills />
    <Contact />
  </div>
</Layout>
