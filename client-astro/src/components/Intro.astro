---
const birthDate = new Date(2003, 6, 13) // July 13, 2003
const today = new Date()
let age = today.getFullYear() - birthDate.getFullYear()
const hasHadBirthday =
  today.getMonth() > birthDate.getMonth() ||
  (today.getMonth() === birthDate.getMonth() && today.getDate() >= birthDate.getDate())
if (!hasHadBirthday) age--
---

<div class="flex gap-x-4">
  <!-- Profile image -->
  <div class="mt-2 md:mt-0 rounded-full hover:scale-110 transition-all ease-in-out duration-[125ms] hover:opacity-60 flex-shrink-0">
    <img
      class="rounded-full"
      src="/IntroImg.jpeg"
      height="100"
      width="100"
      alt="Shobhnik"
    />
  </div>

  <!-- Details -->
  <div>
    <h2 class="text-base md:text-xl 2xl:text-2xl font-bold">👋 Hi, I am Shobhnik</h2>
    <p class="text-slate-700 dark:text-slate-400 text-sm md:text-base 2xl:text-lg mt-3">
      A reliable software engineer based in India, the one you'll regret not working with
    </p>
    <p class="text-slate-700 dark:text-slate-400 pt-2 xl:pt-0 text-sm md:text-base 2xl:text-lg">
      {age}, he/him
    </p>
  </div>
</div>
