---
import { socialData } from '../lib/data'
---

<div class="flex flex-col justify-center mt-10 pb-20">
  <p class="font-[500]">contact, socials &amp; coding profiles.</p>
  <div class="flex flex-col mt-8 gap-y-4">
    {socialData.map((data) => (
      <div class="flex flex-row gap-x-10">
        <p class="text-sm font-[500] capitalize">{data.title}</p>
        <a
          class="text-sm text-slate-700 dark:text-slate-400 2xl:text-base flex items-center justify-center gap-x-1 hover:underline text-gray-500/85 no-underline"
          href={data.link}
          target="_blank"
          rel="noopener noreferrer"
        >
          {data.subText}
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-1">
            <path d="M7 7h10v10"/><path d="M7 17 17 7"/>
          </svg>
        </a>
      </div>
    ))}
  </div>
</div>
